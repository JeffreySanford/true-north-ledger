{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@true-north-ledger/shared-models": ["./libs/shared-models/src/index.ts"],
      "@true-north-ledger/ledger-contracts": ["./libs/ledger-contracts/src/index.ts"],
      "@true-north-ledger/auth-contracts": ["./libs/auth-contracts/src/index.ts"],
      "@true-north-ledger/device-contracts": ["./libs/device-contracts/src/index.ts"],
      "@true-north-ledger/order-contracts": ["./libs/order-contracts/src/index.ts"],
      "@true-north-ledger/inventory-contracts": ["./libs/inventory-contracts/src/index.ts"],
      "@true-north-ledger/audit-contracts": ["./libs/audit-contracts/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
