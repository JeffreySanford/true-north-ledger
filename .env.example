# Non-secret template only. Copy to .env.development or .env.production and
# fill real secret values outside git.

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ledger_dev
POSTGRES_USER=ledger_user
POSTGRES_PASSWORD=<required-secret>

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<optional-secret>
REDIS_URL=redis://localhost:6379

# PgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=<required-secret>
PGADMIN_PORT=5050

# Grafana Configuration
GRAFANA_ADMIN_USER=<required-admin-user>
GRAFANA_ADMIN_PASSWORD=<required-secret>

# API Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api

# JWT/Auth Configuration
JWT_SECRET=<required-secret-at-least-32-random-characters>
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=7d
AUTH_USERNAME=<required-secret>
AUTH_PASSWORD=<required-secret>
AUTH_TENANT_ID=00000000-0000-0000-0000-000000000000

# CORS Configuration
CORS_ORIGIN=http://localhost:4200

# Logging
LOG_LEVEL=debug

# Database Connection URL
DATABASE_URL=postgresql://ledger_user:<required-secret>@localhost:5432/ledger_dev
