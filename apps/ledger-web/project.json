{
  "name": "ledger-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "tnl",
  "sourceRoot": "apps/ledger-web/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/ledger-web",
        "browser": "apps/ledger-web/src/main.ts",
        "tsConfig": "apps/ledger-web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/ledger-web/public"
          }
        ],
        "styles": ["apps/ledger-web/src/styles.scss"],
        "allowedCommonJsDependencies": ["qrcode"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "700kb",
              "maximumError": "1mb"
            },
              {
                "type": "anyComponentStyle",
                "maximumWarning": "5kb",
                "maximumError": "8kb"
              }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "ledger-web:build:production"
        },
        "development": {
          "buildTarget": "ledger-web:build:development"
        }
      },
      "defaultConfiguration": "development",
      "dependsOn": ["ledger-api:serve"],
      "options": {
        "proxyConfig": "apps/ledger-web/proxy.conf.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "ledger-web:build",
        "port": 4200,
        "staticFilePath": "dist/apps/ledger-web/browser",
        "spa": true
      }
    }
  }
}
