{
  "name": "auth-contracts",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/auth-contracts/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:auth"],
  "// targets": "to see all targets run: nx show project auth-contracts --web",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/auth-contracts",
        "main": "libs/auth-contracts/src/index.ts",
        "tsConfig": "libs/auth-contracts/tsconfig.lib.json",
        "assets": ["libs/auth-contracts/*.md"],
        "format": ["cjs"],
        "generatePackageJson": true
      }
    }
  }
}
