{
  "name": "device-contracts",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/device-contracts/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:device"],
  "// targets": "to see all targets run: nx show project device-contracts --web",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/device-contracts",
        "main": "libs/device-contracts/src/index.ts",
        "tsConfig": "libs/device-contracts/tsconfig.lib.json",
        "assets": ["libs/device-contracts/*.md"],
        "format": ["cjs"]
      }
    }
  }
}
